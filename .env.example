# Database (required) — start PostgreSQL via: docker compose up -d
DATABASE_URL="postgresql://algochef:algochef@localhost:5432/algochef"

# OpenAI (optional) — leave empty to use mock mode with sample responses
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# API server
API_PORT=3001

# Frontend → API connection
NEXT_PUBLIC_API_URL="http://localhost:3001"

# CORS origin for the API (must match the web app URL)
WEB_ORIGIN="http://localhost:3000"

# ── Production (Docker Compose) ────────────────────────────────
# POSTGRES_USER=algochef
# POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# POSTGRES_DB=algochef
